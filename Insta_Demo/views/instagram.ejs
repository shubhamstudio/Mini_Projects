<%- include("includes/head.ejs")  %>
<body>
    <h1>This page belongs to @<%= data.name%></h1>
    <button>Follow</button>
    <button>Message</button>

    <h3> Followers:
        <%= data.followers %> &nbsp; Following:<%= data.following %>
    </h3>
    <hr>
    <% for( let post of data.posts) {%>
    <img src="<%=post.image%>" alt="some image">
    <p>
    Likes:<%= post.likes %> &nbsp; Comments:<%= post.comments %>
    </p>
    <% } %>
</body>

</html>